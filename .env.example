# Copy to .env and fill in. Used by the collector to send top-5 emails.
# Create an App Password: Google Account -> Security -> 2-Step Verification
# -> App passwords (requires 2FA enabled).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
NOTIFY_TO=where-to-send-alerts@example.com

# Passphrase that unlocks the hosted (encrypted) leaderboard page:
SITE_PASSWORD=choose-a-passphrase

# Optional: enables "< 30 min by public transport" travel-time filtering.
# Free key from https://portal-api.digitransit.fi/ . Without it, the
# travel_time criterion keeps listings (on_unknown: keep) instead of routing.
DIGITRANSIT_KEY=
